# ─────────────────────────────────────────────────────────────
# Digital Library — Backend environment variables
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────

# Database (used by docker-compose for the Postgres container)
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change_me
DB_NAME=digital_library

# Prisma / pg connection string (must match the values above)
DATABASE_URL="postgresql://postgres:change_me@localhost:5432/digital_library?schema=public"

# JWT auth
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=24h

# Server
PORT=3002

# Comma-separated list of allowed CORS origins (frontend URLs).
# Leave empty to allow all origins in development.
CORS_ORIGINS=http://localhost:3000

# Rate limiting (requests per TTL window)
THROTTLE_TTL=60
THROTTLE_LIMIT=120

# AWS S3 (book covers + PDF storage)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
AWS_BUCKET_NAME=your_s3_bucket_name

# Redis (cache + BullMQ queue)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# AI provider — set ONE of these (Gemini key format starts with "AIza...")
GEMINI_API_KEY=your_gemini_api_key
# OPENAI_API_KEY=your_openai_api_key

# Seed admin account (used by `npm run seed`)
SEED_ADMIN_EMAIL=admin@lib.com
SEED_ADMIN_PASSWORD=admin1234
